# --- Database -----------------------------------------------------------
# Runtime connection: non-superuser role, RLS enforced.
DATABASE_URL="postgres://tikflow_app:tikflow_app@localhost:5432/tikflow?schema=public"

# Migrate-time connection: superuser, has DDL privileges.
DATABASE_MIGRATE_URL="postgres://tikflow:tikflow@localhost:5432/tikflow?schema=public"

# --- Redis --------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Object storage (MinIO in dev) -------------------------------------
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="tikflow"
S3_SECRET_KEY="tikflow-minio-dev"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"
S3_BUCKET_UPLOADS="tikflow-uploads"
S3_BUCKET_RECEIPTS="tikflow-receipts"
S3_BUCKET_KYC="tikflow-kyc"

# --- Mail (MailHog in dev) ---------------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="no-reply@tikflow.local"

# --- ClamAV ------------------------------------------------------------
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"

# --- Auth (apps/web) ---------------------------------------------------
# 32+ byte random string. Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"
# Public base URL of the web app. Required by Auth.js for callback URLs.
AUTH_URL="http://localhost:3000"

# --- Dev login credentials (seeded by packages/db/prisma/seed.ts) ------
# workspace: demo
# email:     owner@demo.com
# password:  tikflow-demo-2026

# --- App ---------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="info"
